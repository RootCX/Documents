{
  "appId": "documents",
  "name": "Documents",
  "version": "0.1.0",
  "description": "Rich document editor with folders and nested pages",
  "dataContract": [
    {
      "entityName": "folders",
      "fields": [
        { "name": "title", "type": "text", "required": true },
        { "name": "parent_id", "type": "entity_link", "references": { "entity": "folders", "field": "id" } },
        { "name": "position", "type": "number" },
        { "name": "icon", "type": "text" }
      ]
    },
    {
      "entityName": "documents",
      "fields": [
        { "name": "title", "type": "text", "required": true },
        { "name": "content", "type": "json" },
        { "name": "folder_id", "type": "entity_link", "references": { "entity": "folders", "field": "id" } },
        { "name": "position", "type": "number" },
        { "name": "icon", "type": "text" },
        { "name": "is_favorite", "type": "boolean" }
      ]
    }
  ],
  "permissions": {
    "permissions": [
      { "key": "folders.create", "description": "Create folders" },
      { "key": "folders.read", "description": "View folders" },
      { "key": "folders.update", "description": "Edit folders" },
      { "key": "folders.delete", "description": "Delete folders" },
      { "key": "documents.create", "description": "Create documents" },
      { "key": "documents.read", "description": "View documents" },
      { "key": "documents.update", "description": "Edit documents" },
      { "key": "documents.delete", "description": "Delete documents" },
      { "key": "public.share", "description": "Create public share links for documents" }
    ]
  },
  "public": {
    "rpcs": [
      { "name": "get_public_document", "scope": ["document_id"] }
    ]
  }
}
